{
  "_name": "05 — Video Frame Sampler (VHS + RTX VSR)",
  "_description": [
    "Load a video, pick N frames at a fixed interval, upscale each one via RTX VSR,",
    "and save all upscaled frames to ComfyUI's output folder.",
    "",
    "This is useful for:",
    "  - Quality-checking a video before committing to full upscale",
    "  - Creating upscaled stills from specific moments in the video",
    "  - Building a before/after contact sheet",
    "",
    "Required nodes:",
    "  - RTXVSRSingleFrameNode            (our custom node)",
    "  - VHS_LoadVideo / LoadVideoPath    (ComfyUI-VideoHelperSuite)",
    "      Install: https://github.com/Kosinkadink/ComfyUI-VideoHelperSuite",
    "",
    "Node chain:",
    "  VHS_LoadVideo ──► VHS_GetImageBatch ──► RTXVSRSingleFrameNode ──► SaveImage",
    "",
    "Widget guide:",
    "  VHS_LoadVideo:      set video_path to your file in inputs/videos/",
    "  VHS_GetImageBatch:  frame_start = 0, length = 8, select_every_nth = 30",
    "                      → picks 8 frames, one every 30 frames (~1s at 30fps)",
    "  RTXVSRSingleFrameNode: scale_factor = 4x",
    "  SaveImage:          filename_prefix = rtx_vsr_sampled_frame"
  ],
  "last_node_id": 4,
  "last_link_id": 3,
  "nodes": [
    {
      "id": 1,
      "type": "VHS_LoadVideo",
      "_note": "Requires ComfyUI-VideoHelperSuite. Install from https://github.com/Kosinkadink/ComfyUI-VideoHelperSuite",
      "pos": [80, 300],
      "size": {"0": 340, "1": 260},
      "flags": {},
      "order": 0,
      "mode": 0,
      "outputs": [
        {"name": "IMAGE",       "type": "IMAGE",  "links": [1],  "slot_index": 0},
        {"name": "frame_count", "type": "INT",    "links": null, "slot_index": 1},
        {"name": "audio",       "type": "AUDIO",  "links": null, "slot_index": 2},
        {"name": "video_info",  "type": "VHS_VIDEOINFO", "links": null, "slot_index": 3}
      ],
      "properties": {"Node name for S&R": "VHS_LoadVideo"},
      "widgets_values": [
        "inputs/videos/test_video.mp4",
        "default",
        0,
        8,
        30,
        "disabled",
        "ComfyUI"
      ]
    },
    {
      "id": 2,
